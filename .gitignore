# Ignore the .env file containing environment variables
.env

# Ignore log files and directories
/logs
*.log

# Ignore Composer dependencies
/vendor

# Ignore node_modules directory
/node_modules

# Ignore IDE and editor specific files
/.idea
/.vscode
*.swp

